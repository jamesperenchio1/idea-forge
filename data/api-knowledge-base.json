    "thailand_southeast_asia": [
      {
        "name": "Thailand Open Government Data (CKAN)",
        "base_url": "https://opend.data.go.th/api/3/action/",
        "key_endpoints": [
          "datastore_search?resource_id={id}&limit=100",
          "package_search?q={keyword}",
          "resource_show?id={id}"
        ],
        "auth": "api_key",
        "auth_notes": "Free registration at data.go.th — generates API key",
        "cost": "free",
        "tags": ["thailand", "government", "environment", "health", "agriculture", "infrastructure", "water", "air", "transport"],
        "notable_datasets": [
          "Air quality by province (PM2.5, PM10)",
          "Flood risk zone maps",
          "Agricultural land use by region",
          "Hospital locations and capacity",
          "Road accident blackspot coordinates",
          "Water quality monitoring stations",
          "Fishing license registrations",
          "Street food vendor registrations by province",
          "Rubber production statistics by province",
          "Dengue case counts by district"
        ],
        "sample_call": "GET https://opend.data.go.th/api/3/action/package_search?q=water+quality&rows=5"
      },
      {
        "name": "Thailand Meteorological Department (TMD)",
        "base_url": "https://data.tmd.go.th/api/",
        "key_endpoints": [
          "WeatherForecast7Days/v1/?uid={uid}&ukey={key}&domain=tmd.go.th&province={province}",
