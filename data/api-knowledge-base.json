        "auth": "api_key",
        "auth_notes": "Free registration at opendata.tmd.go.th",
        "cost": "free",
        "tags": ["thailand", "weather", "climate", "rainfall", "temperature", "humidity", "sea"],
        "notable_datasets": [
          "7-day provincial forecasts",
          "Hourly weather station observations",
          "Daily sea surface temperature (Gulf + Andaman)",
