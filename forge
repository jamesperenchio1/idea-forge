#!/bin/bash
# forge — idea pipeline: batch generate → analyze → build MVP
set -e

REPO=/home/james/idea-forge
CANDIDATES_DIR=$REPO/candidates
TODAY=$(TZ=Asia/Bangkok date +%Y-%m-%d)

mkdir -p "$CANDIDATES_DIR"

usage() {
  echo "forge — app idea pipeline"
  echo ""
  echo "  forge batch [N=5]       Generate N idea seeds via Gemini"
  echo "  forge list              Show today's candidates"
  echo "  forge show <N|file>     Print a candidate's full JSON"
  echo "  forge build <N|file>    Build MVP for a candidate (runs Claude headlessly)"
  echo ""
  echo "Typical flow:"
  echo "  forge batch 8           # Gemini generates 8 seeds"
  echo "  forge list              # See what was generated"
  echo "  forge build 3           # Build MVP for candidate #3"
}

find_candidate() {
  local target=$1
  if [[ "$target" =~ ^[0-9]+$ ]]; then
    ls "$CANDIDATES_DIR/${TODAY}_$(printf '%03d' "$target")_"*.json 2>/dev/null | head -1
  elif [ -f "$target" ]; then
    echo "$target"
  else
    echo ""
  fi
}

case ${1:-help} in

  batch)
    N=${2:-5}
    echo "⚡ Asking Gemini to generate $N idea seeds..."
    echo "   Reading: registry.json + industry-taxonomy.json + api-knowledge-base.json"
    echo ""

    PROMPT=$(sed "s/{{N}}/$N/g; s/{{DATE}}/$TODAY/g" "$REPO/prompts/gemini-seed.md")
    RAW=$(cat "$REPO/data/registry.json" \
              "$REPO/data/industry-taxonomy.json" \
              "$REPO/data/api-knowledge-base.json" \
         | gemini -p "$PROMPT")

    export TODAY CANDIDATES_DIR
    printf '%s' "$RAW" | python3 - <<'PYEOF'
import json, sys, os, re

raw = sys.stdin.read().strip()
# Strip markdown code fences if Gemini wraps the output
raw = re.sub(r'^```(?:json)?\s*', '', raw)
raw = re.sub(r'\s*```$', '', raw)

try:
    ideas = json.loads(raw)
except json.JSONDecodeError as e:
    print(f"❌ JSON parse error: {e}")
    print(f"Raw output (first 800 chars):\n{raw[:800]}")
    sys.exit(1)

today = os.environ['TODAY']
candidates_dir = os.environ['CANDIDATES_DIR']

for i, idea in enumerate(ideas, 1):
    slug = idea['slug']
    idea['_num'] = i
    fname = f"{candidates_dir}/{today}_{i:03d}_{slug}.json"
    with open(fname, 'w') as f:
        json.dump(idea, f, indent=2, ensure_ascii=False)
    apis = ', '.join(a['name'] for a in idea.get('apis', []))
    print(f"  [{i:2d}] {idea['title']}")
    print(f"       {idea['tagline']}")
    print(f"       {idea['industry']}/{idea['sub_industry']} | {idea['geography']} | {idea['stack']}")
    print(f"       APIs: {apis}")
    print()

print(f"✅ {len(ideas)} candidates → candidates/{today}_*.json")
print(f"\nNext: run  forge list  or  forge build <N>")
PYEOF
    ;;

  list)
    FILES=("$CANDIDATES_DIR/${TODAY}_"*.json)
    if [ ! -f "${FILES[0]}" ]; then
      echo "No candidates for $TODAY. Run: forge batch [N]"
      exit 0
    fi
    echo "📋 Candidates for $TODAY:"
    echo ""
    for f in "${FILES[@]}"; do
      python3 - "$f" <<'PYEOF'
import json, sys, os

f = sys.argv[1]
d = json.load(open(f))
num = d.get('_num', os.path.basename(f).split('_')[2])
print(f"  [{num:>2}] {d['title']}")
print(f"       {d['tagline']}")
print(f"       User: {d['target_user'][:110]}")
print(f"       Stack: {d['stack']} | {d['geography']}")
print()
PYEOF
    done
    ;;

  show)
    TARGET=$2
    FILE=$(find_candidate "$TARGET")
    if [ -z "$FILE" ]; then
      echo "Candidate '$TARGET' not found. Run: forge list"
      exit 1
    fi
    cat "$FILE"
    ;;

  build)
    TARGET=$2
    if [ -z "$TARGET" ]; then
      echo "Usage: forge build <N|file>"
      exit 1
    fi

    FILE=$(find_candidate "$TARGET")
    if [ -z "$FILE" ]; then
      echo "❌ Candidate '$TARGET' not found."
      echo "   Run: forge list"
      exit 1
    fi

    IDEA=$(cat "$FILE")
    SLUG=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['slug'])" "$FILE")
    TITLE=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['title'])" "$FILE")

    echo "🏗️  Building MVP: $TITLE"
    echo "   Seed: $FILE"
    echo "   Project will be created at: ~/projects/$SLUG/"
    echo ""

    BUILD_PROMPT=$(cat "$REPO/prompts/claude-build.md")
    FULL_PROMPT="${BUILD_PROMPT}

\`\`\`json
${IDEA}
\`\`\`
"

    claude --dangerously-skip-permissions -p "$FULL_PROMPT"
    ;;

  help|-h|--help)
    usage
    ;;

  *)
    echo "Unknown command: $1"
    usage
    exit 1
    ;;
esac
